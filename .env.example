# Required for live OpenAI-generated nudges and Household Council plans.
# Keep this server-side. Never expose it with a VITE_ or NEXT_PUBLIC_ prefix.
OPENAI_API_KEY=

# Optional secondary model for limited-access or cost-sensitive API accounts.
# When omitted, SynergySplit uses gpt-5.6-luna after trying gpt-5.6-sol.
OPENAI_FALLBACK_MODEL=gpt-5.6-luna
